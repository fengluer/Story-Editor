{
  "name": "story-editor",
  "private": true,
  "version": "0.1.0",
  "description": "Local branching story table editor.",
  "author": "Story Editor Contributors",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "electron:dev": "node electron/dev.cjs",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:preview": "npm run build && electron .",
    "dist:electron": "npm run build && electron-builder",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "build": {
    "appId": "site.banding.story-editor",
    "productName": "Story Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.556.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
